programa {
  funcao inicio() {
   //
   real precoporkilo =10
   real precoPorGrama =precoporkilo/1000  
   real peso
   real precoTotal
   //leitura de dados
   escreva("digiteo peso(g):")
   leia (peso)
   //processamentos
   precoTotal=peso * precoPorGrama
   // saidas
   
   escreva ("valor a pagar:r$ "+precoTotal )
}
}
