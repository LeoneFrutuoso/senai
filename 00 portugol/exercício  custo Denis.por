programa {
  funcao inicio() {
   // informacoes-variaveis
   real precototal,custosDenis = 500,valorHora = 350, lucro
   inteiro horas
   //leitura -entradas
   escreva ("quantas horas foram estimadas: ")
   leia (horas)
   //processamento- calculos
   //precototal =500 + horas * 350
   precototal = 500 + horas* valorHora
   lucro +precototal - custosDenis 
   //apresentar resultados
   escreva ("valorhora
   ")

   
 
 
  
  
  
  
  
  
   









  }
}
