programa {
  funcao inicio() {
    
// 1 indentifica e cria variaveis
inteiro laranjaInicial
inteiro laranjaFinal
inteiro laranjasVendidas
// 2 ler as variaveis
escreva("quantas laranjas no inicio: ")
leia(laranjaInicial)

escreva("qunatas laranjas no final: ")
leia(laranjaFinal)
// 3 calcular / processar
laranjasVendidas = laranjaInicial-laranjaFinal







// 4 apresentar   
escreva("laranjas vendidas no dia " + laranjasVendidas)









  }
}
